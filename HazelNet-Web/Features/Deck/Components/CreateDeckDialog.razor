@using System.ComponentModel.DataAnnotations
@using HazelNet_Application.CQRS.Features.Decks.Commands

<MudDialog>
    <TitleContent>
        Create New Deck
    </TitleContent>

    <DialogContent>
        <MudDivider/>
        <MudStack Spacing="3" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mt-3">
            <MudTextField T="string" @bind-Value="_deckName" Label="Enter Deck Name (required)"
                          Clearable="true" Variant="Variant.Outlined" ShrinkLabel="true"
                          Lines="1" Sizing="InputSizing.Auto" FullWidth="true"
                          Counter="100" MaxLength="100" Immediate="true"/>
            <MudTextField T="string" @bind-Value="_description" Label="Enter Deck Description"
                          Clearable="true" Variant="Variant.Outlined" ShrinkLabel="true"
                          Lines="5" Sizing="InputSizing.Auto" FullWidth="true"
                          Counter="250" MaxLength="250" Immediate="true"/>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" 
                   Variant="Variant.Outlined"
                   Disabled="@(string.IsNullOrEmpty(_deckName))">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int UserId { get; set; }
    [Parameter] public string? InitialName { get; set; }
    [Parameter] public string? InitialDescription { get; set; }
    [Parameter] public int? DeckId { get; set; }

    [Required(ErrorMessage = "Deck Name is required.")]
    private string _deckName = string.Empty;
    private string? _description;

    protected override void OnInitialized()
    {
        _deckName = InitialName ?? "";
        _description = InitialDescription ?? "";
    }

    private void Submit()
    {
        var result = new CreateDeckCommand(
            DeckName: _deckName,
            DeckDescription: _description
        );


        if (DeckId.HasValue)
        {
            MudDialog.Close(
                DialogResult.Ok(
                    new UpdateDeckCommand(DeckId.Value, _deckName, _description)));
        } 
        else
            MudDialog.Close(DialogResult.Ok(result));
    }

    private void Cancel() => MudDialog.Cancel();
}