@page "/"
@layout HomeLayout

<PageTitle>Home</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pt-16 pb-12 text-center">
    
    <MudImage Fluid="true" Src="/Images/HazelNetLogo.svg" 
              Alt="HazelNet Logo" 
              Class="mx-auto d-block rounded-lg" 
              ObjectPosition="ObjectPosition.Center"/>
    
    <MudText Typo="Typo.h1" Class="mb-6" Align="Align.Center" Style="line-height: 1.1; font-size: 4.25rem; outline:none">
        Study smarter,<br/>
        <span style="background: linear-gradient(90deg, #3b82f6, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            remember longer.
        </span>
    </MudText>

    <MudText Typo="Typo.body1" Color="Color.Default" Class="mx-auto mb-10"
             Style="max-width: 600px" Align="Align.Center">
        HazelNet is a web-based flashcard system built for structured learning.
        Create decks, study using spaced repetition, and track progress across devices.
    </MudText>

    <div class="d-flex justify-center gap-4 mb-8">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   Style="border-radius: 16px; font-weight: 700; text-transform: none;" DisableElevation="true">
            Start Studying
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Large" Class=" px-8 py-4"
                   Style="border-radius: 16px; font-weight: 600; text-transform: none;"
                   Href="https://github.com/Zanpakuto/Hazelnet_Web/wiki/System-Documentation"
                   Target="_blank"
                   StartIcon="@Icons.Material.Filled.CheckCircleOutline">
            See how it works
        </MudButton>
    </div>
    
    <MudDivider/>
    
    <MudStack Row="true" Spacing="5" Class="ma-1"
              AlignItems="AlignItems.Center" Justify="Justify.Center"
              Style="background:linear-gradient(135deg, #1e1b4b 0%, #4c1d95 60%, #6d28d9 100%);">
        <MudCard Elevation="0" Style="background: transparent">
            <MudCardContent>
                <MudText Typo="Typo.h2" Color="Color.Info">
                    90%
                </MudText>
                <MudText Typo="Typo.caption" Style="color: white">
                    RETENTION RATE
                </MudText>
            </MudCardContent>
        </MudCard>
        
        <MudCard Elevation="0" Style="background: transparent">
            <MudCardContent>
                <MudText Typo="Typo.h2" Color="Color.Info">
                    3x
                </MudText>
                <MudText Typo="Typo.caption" Style="color: white">
                    FASTER LEARNING
                </MudText>
            </MudCardContent>
        </MudCard>
        
        <MudCard Elevation="0" Style="background: transparent">
            <MudCardContent>
                <MudText Typo="Typo.h2" Color="Color.Info">
                    20-30%
                </MudText>
                <MudText Typo="Typo.caption" Style="color: white">
                    WORKLOAD REDUCTION
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudStack>
    
    <MudDivider/>
    

    <!-- Learning Model -->
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-5 pa-5">
        
        <div class="d-flex flex-column align-center mb-10">
            <MudText Typo="Typo.overline" Color="Color.Primary">
                LEARNING MODEL
            </MudText>
            <MudText Typo="Typo.h2" Align="Align.Center">
                Spaced repetition, 
                <span style="background: linear-gradient(90deg, #3b82f6, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    with intent
                </span>
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="py-3">
                HazelNet prioritizes cards you struggle with while spacing out mastered material. 
                This approach improves long-term retention without unnecessary repetition.
            </MudText>
        </div>
        
    </MudContainer>
    
    <!-- FlashCard Sample-->
    <MudPaper Elevation="20" Class="mx-auto pa-4" 
              Style="max-width: 1000px; border-radius: 20px;">
        <MudPaper Class="mx-auto pa-4 d-flex flex-column" Elevation="2"
                  Style="height: 450px; border-radius: 15px;">
            
            <div class="d-flex flex-row gap-1 ma-2">
                <MudAvatar Color="Color.Error" Style="height:12px; width:12px;"/>
                <MudAvatar Color="Color.Warning" Style="height:12px; width:12px;"/>
                <MudAvatar Color="Color.Success" Style="height:12px; width:12px;"/>
            </div>
            
            <MudPaper Class="d-flex justify-center align-center " Elevation="0" Style="height: 450px">
                <MudCard Outlined="true" Style="border-radius: 20px; height: 200px; width: 400px" Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.body2" Color="Color.Primary" Align="Align.Center">FLASHCARD</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Class="mb-5" Align="Align.Center" Color="Color.Dark" Typo="Typo.h3">
                            What is the time <br/>complexity of Merge Sort?
                        </MudText>
                        <MudSpacer/>
                        <MudDivider/>
                        <div class="d-flex flex-row gap-5 ma-5 align-center justify-center">
                            <MudAvatar Color="Color.Primary" Style="height:12px; width:12px;"/>
                            <MudAvatar Color="Color.Primary" Style="height:12px; width:12px;"/>
                            <MudAvatar Color="Color.Primary" Style="height:12px; width:12px;"/>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudPaper>
            
        </MudPaper>
    </MudPaper>
    
       <!--How it Works-->
    <MudContainer Id="how-section"
                  MaxWidth="MaxWidth.Medium" Class="pa-10 scroll-target">

        <MudGrid Spacing="6" AlignItems="AlignItems.Center">

            <!-- Left: Image -->
            <MudItem xs="12" md="6">
                <MudPaper Elevation="5" 
                          Style="border-radius: 16px; overflow: hidden; height: 400px"
                          Class="justify-center align-content-center">
                    <MudImage Src="/Images/studying.png" Fluid="true" Alt="Student studying"
                              ObjectFit="ObjectFit.Fill"
                              Style="width: 100%; height: 100%;"/>
                </MudPaper>
            </MudItem>

            <!-- Right: Steps -->
            <MudItem xs="12" md="6" Class="justify-center align-content-center">
                <MudStack Spacing="6">

                    <div class="d-flex flex-row align-start gap-4">
                        <MudAvatar Color="Color.Primary">1</MudAvatar>
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6">Create Your Decks</MudText>
                            <MudText Typo="Typo.body2" Style="line-height: 1.6">
                                Build cards with clear questions and answers.
                                Organize cards using decks and structured content.
                            </MudText>
                        </MudStack>
                    </div>

                    <div class="d-flex flex-row align-start gap-4">
                        <MudAvatar Color="Color.Primary">2</MudAvatar>
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6">Study with Focus</MudText>
                            <MudText Typo="Typo.body2" Style="line-height: 1.6">
                                Enter focused review sessions. Scheduling adapts
                                to your performance and confidence over time.
                            </MudText>
                        </MudStack>
                    </div>

                    <div class="d-flex flex-row align-start gap-4">
                        <MudAvatar Color="Color.Primary">3</MudAvatar>
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6">Track Mastery</MudText>
                            <MudText Typo="Typo.body2" Style="line-height: 1.6">
                                Watch your knowledge base grow. Heatmaps and
                                progress metrics show your long-term improvement.
                            </MudText>
                        </MudStack>
                    </div>

                </MudStack>
            </MudItem>

        </MudGrid>

    </MudContainer>
    
    <!--Feature Section-->
    <MudContainer Id="feature-section"
    MaxWidth="MaxWidth.Medium" Class="pa-10 scroll-target">

    <div class="d-flex flex-column align-center mb-10">
        <MudText Typo="Typo.h2" Align="Align.Center" GutterBottom="true">
            Designed for 
            <span style="background: linear-gradient(90deg, #3b82f6, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            Retention
            </span>
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Style="max-width: 520px">
            Scientific methodology meets structured design to create
            the ultimate learning environment.
        </MudText>
    </div>

    <MudGrid Spacing="4" Justify="Justify.Center">

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Outlined="true" Class="pa-6 d-flex flex-column" Style="border-radius: 12px; height: 100%">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome"
                         Color="Color.Primary" Size="Size.Large" Class="mb-4"/>
                <MudText Typo="Typo.h6" GutterBottom="true">Smart Spaced Repetition</MudText>
                <MudText Typo="Typo.body2" Style="line-height: 1.6">
                    Our algorithm predicts your forgetting curve and schedules
                    reviews at the optimal moment of cognitive effort.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Outlined="true" Class="pa-6 d-flex flex-column" Style="border-radius: 12px; height: 100%">
                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff"
                         Color="Color.Primary" Size="Size.Large" Class="mb-4"/>
                <MudText Typo="Typo.h6" GutterBottom="true">Deep Work Mode</MudText>
                <MudText Typo="Typo.body2" Style="line-height: 1.6">
                    An ultra-clean study interface that hides distractions and
                    peripheral noise to maximize your focus time.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Outlined="true" Class="pa-6 d-flex flex-column" Style="border-radius: 12px; height: 100%">
                <MudIcon Icon="@Icons.Material.Filled.BarChart"
                         Color="Color.Primary" Size="Size.Large" Class="mb-4"/>
                <MudText Typo="Typo.h6" GutterBottom="true">Detailed Insights</MudText>
                <MudText Typo="Typo.body2" Style="line-height: 1.6">
                    Track your mastery level, review velocity, and daily streaks
                    with high-fidelity performance metrics.
                </MudText>
            </MudPaper>
        </MudItem>

    </MudGrid>

</MudContainer>
    
    <!--Our Mission-->
    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-10 text-center">
        
        <MudText Typo="Typo.h1" 
                 Color="Color.Primary"
                 Align="Align.Center" 
                 GutterBottom="true">
            <span style="background: linear-gradient(90deg, #3b82f6, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            Our Mission
            </span>
        </MudText>

        <MudText Typo="Typo.body1" 
                 Align="Align.Center" 
                 Style="line-height: 1.8" 
                 Class="mb-10">
            HazelNet was born from a simple observation: most study tools are built for cramming, not mastery. 
            We are dedicated to empowering lifelong learners by bridging the gap between cognitive science 
            and structured productivity. Our goal is to make deep work an effortless habit, 
            helping you retain what matters most in an increasingly noisy world.
        </MudText>
        
        
    </MudContainer>

   

</MudContainer>
