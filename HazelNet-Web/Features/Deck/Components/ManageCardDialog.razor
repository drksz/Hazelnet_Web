@using System.ComponentModel.DataAnnotations
@using HazelNet_Application.CQRS.Abstractions
@using HazelNet_Application.CQRS.Features.Cards.Commands
@using HazelNet_Application.CQRS.Features.Cards.Queries
@using HazelNet_Domain.Models
@inject ICommandHandler<CreateCardCommand>  CreateCardCommandHandler
@inject IQueryHandler<GetAllCardsInDeckQuery, List<Card>> GetAllCardsInDeckQueryHandler
@inject ICommandHandler<UpdateCardCommand> UpdateCardCommandHandler

<MudDialog>
    <TitleContent>
        @DeckName
    </TitleContent>
    
    <DialogContent>
        <MudCard Elevation="0" Outlined="true" Class="pa-5" >
            <MudCardHeader>
                <CardHeaderContent> 
                    <MudText Typo="Typo.h5">
                        Create New Card
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            
            <MudCardContent>
                <MudStack Row="true">
                    <MudTextField T="string" @bind-Value="FrontOfCard" Label="Front"  Required="true"
                                  Clearable="true" Variant="Variant.Outlined" ShrinkLabel="true"
                                  Lines="3" Sizing="InputSizing.Auto" FullWidth="true"
                                  Immediate="true" Counter="0"
                                  Placeholder="Enter question or term..."/>
                    <MudTextField T="string" @bind-Value="BackOfCard" Label="Back"
                                  Clearable="true" Variant="Variant.Outlined" ShrinkLabel="true"
                                  Lines="3" Sizing="InputSizing.Auto" FullWidth="true" Counter="0"
                                  Immediate="true"  Placeholder="Enter answer or definition..."/>
                </MudStack>
            </MudCardContent>
            
            <MudCardActions Class="justify-end align-center">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Ripple="true"
                           Size="Size.Medium"
                           Disabled="@_isFrontOfCardEmpty"
                           OnClick="@AddNewCard">
                    Add Card
                </MudButton>
            </MudCardActions>
        </MudCard>
        
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-5">
            <MudText Typo="Typo.h4">
                Cards in this Deck (@TotalNumberOfCards)
            </MudText>
            
            
            @foreach (var card in _draftCards)
            {
                <MudPaper @key="card.Id" Elevation="0" Outlined="true" Class="pa-3 my-2">
                    
                    <MudStack Row="true"
                              Justify="Justify.Center"
                              Spacing="3"
                              AlignItems="AlignItems.Center">
                        
                        <MudTextField T="string" @bind-Value="card.FrontOfCard" Label="Front"  Required="true"
                                      Clearable="true" Variant="Variant.Outlined" ShrinkLabel="true"
                                      Lines="3" Sizing="InputSizing.Auto" FullWidth="true"
                                      Immediate="true" Counter="0"
                                     />
                        <MudTextField T="string" @bind-Value="card.BackOfCard" Label="Back"
                                      Clearable="true" Variant="Variant.Outlined" ShrinkLabel="true"
                                      Lines="3" Sizing="InputSizing.Auto" FullWidth="true" Counter="0"
                                      Immediate="true" />
                        
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                       Variant="Variant.Outlined" 
                                       Color="Color.Error" 
                                       Size="Size.Medium" />

                    </MudStack>
                    
                </MudPaper>
            }
            
            
        </MudContainer>
    </DialogContent>
    <DialogActions>
        
        <MudButton Variant="Variant.Outlined"
                   DropShadow="false"
                   Color="Color.Default"
                   Size="Size.Large"
                   OnClick="@Cancel">
            Cancel
        </MudButton>
            
        <MudButton Variant="Variant.Filled"
                   DropShadow="false"
                   Color="Color.Primary"
                   Size="Size.Large"
                   OnClick="@SaveChanges">
            Save Changes
        </MudButton>


  
    </DialogActions>
</MudDialog>


@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public int DeckId { get; set; }
    [Parameter]  public required string DeckName { get; set; }
    
    public required string FrontOfCard;
    public string BackOfCard;

    private bool _isFrontOfCardEmpty => string.IsNullOrEmpty(FrontOfCard);
    
    public int TotalNumberOfCards = 0;
    
    // Original list representing the source of truth
    public List<Card> Cards = new();
    
    // Draft list for UI binding
    private List<Card> _draftCards = new();
    

    protected override async Task OnInitializedAsync()
    {
        await LoadCards();
    }
    
    private async Task LoadCards()
    {
        var query = new GetAllCardsInDeckQuery(DeckId);
        Cards = await GetAllCardsInDeckQueryHandler.Handle(query);
        TotalNumberOfCards = Cards.Count;
        
        // Create a deep copy for editing so changes do not reflect immediately
        _draftCards = Cards.Select(c => new Card 
        { 
            Id = c.Id, 
            FrontOfCard = c.FrontOfCard, 
            BackOfCard = c.BackOfCard, 
            DeckId = c.DeckId 
        }).ToList();
    }

    public async Task AddNewCard()
    {
        var command = new CreateCardCommand(
            0,
            FrontOfCard,
            BackOfCard,
            DeckId
        );

        await CreateCardCommandHandler.Handle(command);
        var query = new GetAllCardsInDeckQuery(DeckId);
        Cards = await GetAllCardsInDeckQueryHandler.Handle(query);
        
        TotalNumberOfCards++;
        FrontOfCard = string.Empty;
        BackOfCard = string.Empty;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SaveChanges()
    {
        // Iterate through drafts and send update commands
        // Note: A batch update command would be more efficient here if your architecture supports it.
        foreach (var draft in _draftCards)
        {
            var original = Cards.FirstOrDefault(c => c.Id == draft.Id);
            
            // Only update if changes were made
            if (original != null && (original.FrontOfCard != draft.FrontOfCard || original.BackOfCard != draft.BackOfCard))
            {
                var updateCommand = new UpdateCardCommand(draft.Id, draft.FrontOfCard, draft.BackOfCard, draft.DeckId);
                await UpdateCardCommandHandler.Handle(updateCommand);
            }
        }
        
        MudDialog.Close(DialogResult.Ok(true));
    }
    

}
