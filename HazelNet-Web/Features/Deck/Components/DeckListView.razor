@using HazelNet_Application.CQRS.Abstractions
@using HazelNet_Application.CQRS.Features.Decks.Commands

@inject ICommandHandler<DeleteDeckCommand> DeleteDeckCommandHandler
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICommandHandler<UpdateDeckCommand> UpdateDeckHandler
@inject ICommandHandler<ClearCardsInDeckCommand> ClearCardsInDeckHandler

<MudCard Outlined="true" 
         Class="pa-5"
         Style="width: 100%;">
    <MudCardContent>
        <MudGrid Spacing="4" AlignItems="AlignItems.Center">

            <MudItem xs="12" sm="5">
                <MudText Typo="Typo.h4">@Deck.Name</MudText>
                <MudText Typo="Typo.body1" GutterBottom="true">
                    @Deck.Description
                </MudText>

                <MudStack Row="true" Spacing="6" Class="mt-4">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.overline">Last Studied</MudText>
                        <MudText Typo="Typo.body2">@GetRelativeTime(Deck.LastDateAccessed)</MudText>
                    </MudStack>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.overline">Due Today</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Error">@Deck.DueToday</MudText>
                    </MudStack>
                </MudStack>
            </MudItem>


            <MudItem xs="12" sm="7">
                <MudStack Spacing="4">
                   
                    <div>
                        <MudProgressLinear Color="Color.Info"
                                           Value="@Deck.MasteredPercentage"
                                           Size="Size.Large"
                                           Class="mt-5"
                                           Rounded="true" />
                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-1">
                            <MudText Typo="Typo.caption">
                                @Deck.MasteredCards / @Deck.TotalNumberOfCards mastered
                            </MudText>
                            <MudText Typo="Typo.caption">@Deck.MasteredPercentage%</MudText>
                        </MudStack>
                    </div>

                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   FullWidth="true"
                                   OnClick="@StudyDeck">
                            Study Now
                        </MudButton>

                        <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                 Color="Color.Default"
                                 Size="Size.Medium"
                                 TransformOrigin="Origin.BottomLeft"
                                 Dense="true">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                         OnClick="@EditDeck">
                                Edit
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.CreditCard"
                                         OnClick="@ManageCard">
                                Cards
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.ClearAll"
                                         OnClick="@(() => ClearDeckOfCards(Deck.Id))">
                                Clear
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                         IconColor="Color.Error"
                                         OnClick="@DeleteDeck">
                                <MudText Color="Color.Error">Delete</MudText>
                            </MudMenuItem>
                        </MudMenu>
                        
                        
                    </MudStack>

                </MudStack>
            </MudItem>

        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public DeckViewModel Deck { get; set; }
    [Parameter] public EventCallback<int> OnDeckDeleted { get; set; }
    [Parameter] public EventCallback<UpdateDeckCommand> OnDeckUpdated { get; set; }
    [Parameter] public EventCallback OnCardsUpdated { get; set; }

    
    

    private string GetRelativeTime(DateTime date)
    {
        var diff = DateTime.UtcNow - date;

        if (diff.TotalMinutes < 1)    return "Just now";
        if (diff.TotalMinutes < 60)   return $"{(int)diff.TotalMinutes} minutes ago";
        if (diff.TotalHours < 24)     return $"{(int)diff.TotalHours} hours ago";
        if (diff.TotalDays < 7)       return $"{(int)diff.TotalDays} days ago";
        if (diff.TotalDays < 30)      return $"{(int)(diff.TotalDays / 7)} weeks ago";
        if (diff.TotalDays < 365)     return $"{(int)(diff.TotalDays / 30)} months ago";

        return $"{(int)(diff.TotalDays / 365)} years ago";
    }

    private async Task EditDeck()
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["InitialName"] = Deck.Name,
                ["InitialDescription"] = Deck.Description,
                ["DeckId"] = Deck.Id
            };
            
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true,
                Position = DialogPosition.Center
            };
            
            var dialog = await DialogService.ShowAsync<CreateDeckDialog>(
                "Edit Deck", parameters, options);

            var result = await dialog.Result;

            if (!result.Canceled && result.Data is UpdateDeckCommand command)
            {
                await UpdateDeckHandler.Handle(command);

                Snackbar.Add("Deck updated!", Severity.Success);

                // Notify parent
                await OnDeckUpdated.InvokeAsync(command);
            }
        }
        catch (UnauthorizedAccessException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (KeyNotFoundException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("An error occurred while deleting the deck.", Severity.Error);
        }
    }

    private async Task DeleteDeck()
    {
        try
        {
            var command = new DeleteDeckCommand (Deck.Id);
        
            await DeleteDeckCommandHandler.Handle(command);
        
            Snackbar.Add($"{Deck.Name} deleted successfully", Severity.Info);
        
            
            await OnDeckDeleted.InvokeAsync(Deck.Id);
            await OnCardsUpdated.InvokeAsync();
            
        }
        catch (UnauthorizedAccessException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (KeyNotFoundException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("An error occurred while deleting the deck.", Severity.Error);
        }
    }

    private async Task ManageCard()
    {
        try
        {
            var parameters = new DialogParameters
            {
                ["DeckId"] = Deck.Id,
                ["DeckName"] = Deck.Name
            };
            
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true,
                Position = DialogPosition.Center,
                BackdropClick = false
            };
            
            var dialog = await DialogService.ShowAsync<ManageCardDialog>(
                "Manage Card", parameters, options);

            var result = await dialog.Result;

            if (!result.Canceled || result.Canceled)
            {
                await OnCardsUpdated.InvokeAsync();
                StateHasChanged();
            }
        }
        catch (UnauthorizedAccessException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (KeyNotFoundException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("An error occurred while managing the cards.", Severity.Error);
        }
    }

    public async Task StudyDeck()
    {
        try
        {
            //parameter
            var parameters = new DialogParameters
            {
                ["DeckId"] = Deck.Id,
                ["DeckName"] = Deck.Name
            };
            
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true,
                Position = DialogPosition.Center,
                BackdropClick = false
            };
            
            var dialog = await DialogService.ShowAsync<StudyDeckkDialog>(
                "Study Deck", parameters, options);

            var result = await dialog.Result;
            
            await OnCardsUpdated.InvokeAsync(); 
            StateHasChanged();
   
        }
        catch (UnauthorizedAccessException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (KeyNotFoundException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("An error occurred while trying to study deck.", Severity.Error);
        }
    }

    public async Task ClearDeckOfCards(int id)
    {
        
        try
        {
            var command = new ClearCardsInDeckCommand(id);
            await ClearCardsInDeckHandler.Handle(command);
            Snackbar.Add($"{Deck.Name} successfully cleared.", Severity.Info);
            await OnCardsUpdated.InvokeAsync();
            StateHasChanged();
        }
        catch (UnauthorizedAccessException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (KeyNotFoundException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("An error occurred while clearing the deck.", Severity.Error);
        }
    }
}