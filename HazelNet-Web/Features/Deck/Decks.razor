@page "/decks"

@using HazelNet_Domain.Models
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using HazelNet_Application.CQRS.Abstractions
@using HazelNet_Application.CQRS.Features.Decks.Queries
@using HazelNet_Application.CQRS.Abstractions
@using HazelNet_Application.CQRS.Features.Decks.Commands
@using HazelNet_Web.Features.Deck.Components
@using HazelNet_Web.ViewModel
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IQueryHandler<GetDecksVMQuery, List<DeckViewModel>> GetDecksVMHandler
@inject ICommandHandler<CreateDeckCommand> CreateDeckHandler
@inject IDialogService DialogService
@inject ISnackbar Snackbar


@attribute [Authorize]


<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-5" >
    <MudGrid Spacing="3" Justify="Justify.Center" >
        <MudItem>
            <MudText Typo="Typo.h3" Align="Align.Left">
                Decks
            </MudText>
        </MudItem>
        <MudSpacer/>
        <MudItem>
            <MudButton Variant="Variant.Outlined" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="CreateNewDeck">
                New Deck
            </MudButton>
        </MudItem>
    </MudGrid>
    
    <MudStack Row="true" Spacing="20"  Justify="Justify.SpaceAround"AlignItems="AlignItems.Center" Class="mt-5">
        <MudStack Spacing="0" >
            <MudText Typo="Typo.h3">
                @_NumOfDecks
            </MudText>
            <MudText Typo="Typo.body1">
                Decks
            </MudText>
        </MudStack>
        
        <MudStack Spacing="0" >
            <MudText Typo="Typo.h3">
                @_TotalCards
            </MudText>
            <MudText Typo="Typo.body1">
                Total Cards
            </MudText>
        </MudStack>
        
        <MudStack Spacing="0" >
            <MudText Typo="Typo.h3" Color="Color.Success">
                @_CompletedDecks
            </MudText>
            <MudText Typo="Typo.body1">
                Completed Decks
            </MudText>
        </MudStack>
        
        <MudStack Spacing="0" >
            <MudText Typo="Typo.h3" Color="Color.Error">
                @_ToTaldueToday
            </MudText>
            <MudText Typo="Typo.body1">
                Due today
            </MudText>
        </MudStack>
    </MudStack>
    
    <MudGrid Spacing="5" Justify="Justify.Center" Class="mt-5 px-20" xs="12">
        
        <MudItem sm="4" md="6"
                 Class="d-flex align-center justify-center">
            
            <MudTextField @bind-Value="_HighlightedText"  Variant="Variant.Outlined"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                          AdornmentColor="Color.Primary"
                          Immediate="true" Label="Search for a Deck"/>
        </MudItem>
        
        
        <MudItem sm="4" md=4
                 Class="d-flex align-center justify-center">
            <MudSelect T="string" Label="Sorting Method" FullWidth="true" FitContent="true"
                       Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Sort"
                       AdornmentColor="Color.Primary" @bind-Value="_SortDisplay" @bind-Value:after="SortDecks">
                <MudSelectItem Value="@("due_first")">Due first</MudSelectItem>
                <MudSelectItem Value="@("by_name")">By Name</MudSelectItem>
                <MudSelectItem Value="@("date_added")">Date Added</MudSelectItem>
                <MudSelectItem Value="@("recently_accessed")">Recently Accessed</MudSelectItem>
            </MudSelect>
        </MudItem>
        
        <MudItem sm="4" md="2"
                 Class="d-flex align-center justify-center">
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Large">
                <MudIconButton Icon="@Icons.Material.Filled.List"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.GridView"></MudIconButton>
            </MudButtonGroup>
        </MudItem>

    </MudGrid>
    
   <!-- Card Component-->
    <MudGrid Spacing="5" Justify="Justify.Center" Class="mt-5 px-20">

        @if (_NumOfDecks == 0)
        {
            <MudStack Spacing="3" Class="ma-10 pa-10"
                      AlignItems="AlignItems.Center" Justify="Justify.Center">
                <MudText Typo="Typo.h2" Color="Color.Primary">
                    No decks yet.
                </MudText>
                <MudText Typo="Typo.body1">
                    Create your first deck to start studying.
                </MudText>    
            </MudStack>
            
        }
        @foreach (var deck in _DeckList)
        {
            <MudItem @key="deck.Id" sm="12" md="4" lg="3" Class="d-flex">
                <DeckView Deck="deck" 
                          OnDeckDeleted="RemoveDeckFromList"
                          OnDeckUpdated="UpdateDeckInList"
                          OnDeckCleared="ClearedDeckUpdate"/>
            </MudItem>
        }

    </MudGrid>
    
    
</MudContainer>

@code {
    
    private List<DeckViewModel> _DeckList = new();
    
    
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private string? _Username;
    private string? _UserId;
    private string? _UserEmail;

    private string? _HighlightedText;

    private string _SortDisplay = "Date Added";
    
    private int _NumOfDecks;
    private int _TotalCards;
    private int _ToTaldueToday;
    private int _CompletedDecks;

    

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                _Username = user.Identity.Name;
                _UserEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                _UserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            }
            if (!int.TryParse(_UserId, out int parsedUserId)) return;
            
            _DeckList = await GetDecksVMHandler.Handle(new GetDecksVMQuery(parsedUserId));
            _NumOfDecks = _DeckList.Count;
            SortDecks();
            
        }
    }
    
    private async Task CreateNewDeck()
    {
        if (!int.TryParse(_UserId, out int parsedUserId)) return;
        
        var parameters = new DialogParameters { ["UserId"] = parsedUserId };
        
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true,
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<CreateDeckDialog>("Create New Deck", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateDeckCommand command)
        {

            await CreateDeckHandler.Handle(command);
            
           
            
            _DeckList = await GetDecksVMHandler.Handle(new GetDecksVMQuery(parsedUserId));
            _NumOfDecks = _DeckList.Count;
            
            Snackbar.Add("Deck successfully created", Severity.Success);
            StateHasChanged();
            
        }
    }

    private void SortDecks()
    {
        _DeckList = _SortDisplay switch
        {
            //Implement Due First. Must return deck with cards that are due the soonest
            "due_first"          => _DeckList.OrderBy(x => x.Name).ToList(),
            "by_name"            => _DeckList.OrderBy(x => x.Name).ToList(),
            "date_added"         => _DeckList.OrderBy(x => x.CreationDate).ToList(),
            "recently_accessed"  => _DeckList.OrderByDescending(x => x.LastDateAccessed).ToList(),
            _                    => _DeckList
        };
    }
    
    private void RemoveDeckFromList(int deletedDeckId)
    {
        _DeckList = _DeckList
            .Where(d => d.Id != deletedDeckId)
            .ToList();

        _NumOfDecks = _DeckList.Count;

        StateHasChanged();
    }

    private void UpdateDeckInList(UpdateDeckCommand updated)
    {
        var deck = _DeckList.FirstOrDefault(d => d.Id == updated.DeckId);

        if (deck != null)
        {
            deck.Name = updated.DeckName;
            deck.Description = updated.DeckDescription;
        }

        StateHasChanged();
    }

    private void ClearedDeckUpdate()
    {
        StateHasChanged();
    }
    
    
}
